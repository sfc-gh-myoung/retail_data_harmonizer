# Backend API Dockerfile
FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install uv

# Copy project files
COPY pyproject.toml uv.lock ./
COPY cli/ ./cli/
COPY backend/ ./backend/

# Install dependencies
RUN uv sync --frozen --no-dev

# Expose API port
EXPOSE 8000

# Run API server
CMD ["uv", "run", "uvicorn", "backend.api:app", "--host", "0.0.0.0", "--port", "8000"]
